# VEYN daemon configuration
# Default search path: ./veyn.toml → ~/.config/veyn/veyn.toml
# Override with: veyn-core --config /path/to/veyn.toml
#
# All keys are optional; unset keys fall back to defaults.

[server]
# REST + WebSocket API port
port = 7700
# HealthKit TCP relay port
healthkit_port = 7701

[security]
# Require Bearer token on all connections (strongly recommended: true)
require_auth = true
# Custom token file location (default: ~/.local/share/veyn/token)
# token_path = "~/.local/share/veyn/token"
# Cross-origin origins allowed to connect (empty = localhost only)
cors_origins = []
# Audit log path (default: ~/.local/share/veyn/audit.log)
# audit_log_path = "~/.local/share/veyn/audit.log"
# Strip raw keystroke content; expose only semantic intent (recommended: true)
strip_raw_hid = true
# Max REST requests per second per client IP (0 = disabled)
rate_limit_rps = 100

# Scope-limited tokens are configured in ~/.local/share/veyn/tokens.json:
# [
#   { "token": "<hex>", "label": "my-agent",   "scopes": ["read"] },
#   { "token": "<hex>", "label": "midi-only",  "scopes": ["source:midi"] },
#   { "token": "<hex>", "label": "ai-agent",   "scopes": ["read", "tier:semantic"] }
# ]
# Scope values:
#   "read"               — GET/HEAD only; POST/PUT/DELETE are rejected
#   "source:<class>"     — filter context to a specific adapter class
#   "tier:raw"           — expose full VeynEvent stream (unfiltered)
#   "tier:filtered"      — expose compression-filtered events only
#   "tier:semantic"      — expose only ContextSnapshot; no raw events (AI agents)

[adapters]
# Emit synthetic biometric events (for development / CI)
mock = false
# Enable Bluetooth Low Energy heart-rate adapter
ble = false
# Enable EEG/OSC adapter
eeg = false
# UDP port for OSC input
osc_port = 9000
# Linux evdev HID adapter (/dev/input/event*) — keyboard, mouse, gamepad
evdev = false
# Linux raw USB HID adapter (/dev/hidraw*)
hidraw = false
# MIDI adapter (midir — first available port)
midi = false
# Serial/UART adapter
# serial_port = "/dev/ttyUSB0"
# serial_baud = 115200
# Filesystem watcher — paths to watch recursively
# fs_watch_paths = ["/tmp/veyn-watch"]

[logging]
# Tracing level: error | warn | info | debug | trace
level = "info"
# Append-only JSONL event audit log
jsonl_path = "veyn-events.jsonl"

[plugins]
# Directory scanned for WASM plugin manifests
dir = "plugins"

[mqtt]
# MQTT broker URL — comment out to disable
# url = "mqtt://localhost:1883"

[presence]
# Seconds without an event before a device is marked absent
timeout_secs = 30

[memory]
# Enable the biometric memory layer (ambient writer + REST + MCP tools)
enabled = true
# How often the ambient writer fires and stores a summary record (seconds)
ambient_interval_secs = 900   # 15 minutes
# Maximum number of Ambient records to retain; oldest are pruned when exceeded.
# Semantic records written by the AI are never auto-pruned.
max_records = 10000

[compression]
# Path to hot-reloadable semantic rules file
rules_path = "rules.toml"
# Maximum number of context snapshots to keep in history
context_history_size = 32
# Default context tier exposed to authenticated clients.
# raw      — full VeynEvent stream (all adapters)
# filtered — compression-filtered events (delta + debounce applied)
# semantic — ContextSnapshot only; no raw events (recommended for AI agents)
context_tier = "semantic"
# Optional: enable lightweight local SLM (llama.cpp) as secondary synthesis pass
# when intent_confidence < 0.6. Requires llama.cpp installed and accessible.
# use_slm = false
# slm_path = "/usr/local/bin/llama-cli"
# slm_model = "/path/to/model.gguf"

# Per-metric temporal debounce (milliseconds).
# Events arriving faster than this window are dropped.
[compression.debounce_ms]
heart_rate       = 1000
hrv              = 2000
spo2             = 5000
steps            = 500
respiratory_rate = 3000
skin_temperature = 10000
battery          = 60000

# Per-metric magnitude thresholds.
# Changes smaller than epsilon are treated as noise and dropped.
[compression.epsilons]
heart_rate       = 1.0
hrv              = 2.0
spo2             = 0.5
steps            = 10.0
respiratory_rate = 0.5
skin_temperature = 0.1
battery          = 1.0
