# VEYN daemon environment variables
# Copy this file to .env and adjust values, or set them in veyn.toml instead.
# Priority: CLI flags > env vars > veyn.toml > defaults

# ── Server ─────────────────────────────────────────────────────────────────────

# API port for REST + WebSocket (default: 7700)
# VEYN_PORT=7700

# HealthKit TCP relay port (default: 7701)
# VEYN_HK_PORT=7701

# ── Security ───────────────────────────────────────────────────────────────────

# Disable token authentication — NEVER use in production (default: false)
# VEYN_NO_AUTH=false

# ── Adapters ──────────────────────────────────────────────────────────────────

# Emit synthetic biometric events for development/testing (default: false)
VEYN_MOCK=true

# Enable the BLE heart-rate adapter (default: false)
# VEYN_BLE=true

# Enable the EEG/OSC adapter (default: false)
# VEYN_EEG=true

# UDP port for OSC/EEG input (default: 9000)
# VEYN_OSC_PORT=9000

# ── Logging ───────────────────────────────────────────────────────────────────

# Append-only JSONL event log path (default: veyn-events.jsonl)
# VEYN_LOG=veyn-events.jsonl

# Tracing log level: error | warn | info | debug | trace
# RUST_LOG=info

# ── Plugins ───────────────────────────────────────────────────────────────────

# Directory scanned for WASM plugin manifests (default: plugins)
# VEYN_PLUGINS_DIR=plugins

# ── MQTT ──────────────────────────────────────────────────────────────────────

# MQTT broker URL for the smart-home bridge (unset = disabled)
# VEYN_MQTT_URL=mqtt://localhost:1883

# ── Presence ──────────────────────────────────────────────────────────────────

# Seconds of silence before a device is marked absent (default: 30)
# VEYN_PRESENCE_TIMEOUT=30
