# VEYN Daemon Environment Variables
# Copy this file to .env and customize for your deployment

# =============================================================================
# CORE SETTINGS
# =============================================================================

# Port for the REST / WebSocket API (default: 7700)
VEYN_PORT=7700

# Port for HealthKit TCP relay (default: 7701)
VEYN_HK_PORT=7701

# Path for append-only JSONL event log (default: veyn-events.jsonl)
VEYN_LOG=/var/log/veyn/veyn-events.jsonl

# Directory for WASM plugin discovery (default: plugins)
VEYN_PLUGINS_DIR=/opt/veyn/plugins

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable mock data generator for testing (default: false)
VEYN_MOCK=false

# Enable BLE adapter for wearable devices (default: false)
VEYN_BLE=false

# Enable EEG/OSC adapter for brain-computer interface (default: false)
VEYN_EEG=false

# OSC/UDP port for EEG input (default: 9000)
VEYN_OSC_PORT=9000

# =============================================================================
# INTEGRATIONS
# =============================================================================

# MQTT broker URL for smart-home bridge (unset disables)
# Example: mqtt://localhost:1883
VEYN_MQTT_URL=

# =============================================================================
# PRESENCE DETECTION
# =============================================================================

# Seconds of silence before device marked absent (default: 30)
VEYN_PRESENCE_TIMEOUT=30

# =============================================================================
# LOGGING
# =============================================================================

# Log level: error, warn, info, debug, trace (default: info)
RUST_LOG=info
